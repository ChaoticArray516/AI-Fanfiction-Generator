---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlobalNav from '../components/GlobalNav.astro';

const description = "Explore the powerful features of AI Fanfiction Generator";
const title = "Features - AI Fanfiction Generator";

// Check if user is authenticated
const isAuthenticated = !!Astro.locals.user?.id;

// Determine workbench link - use /guest for non-authenticated users
const workbenchLink = isAuthenticated ? '/dashboard' : '/guest';

// Get current path for navigation highlighting
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description}>
  <slot name="navbar" slot="navbar">
    <GlobalNav currentPath={currentPath} />
  </slot>

  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center pt-20 overflow-hidden">
    <!-- Animated Nebula Background -->
    <div class="nebula-container">
      <div class="nebula-blob blob-1"></div>
      <div class="nebula-blob blob-2"></div>
      <div class="stars"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 w-full text-center relative z-10 pt-12">
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight tracking-tight mb-6">
        Everything You Need to<br/>
        <span class="text-gradient">Write Your Best Story</span>
      </h1>
      <p class="text-lg md:text-xl text-[#A09CB8] mb-10 max-w-2xl mx-auto font-medium">
        Powerful tools designed specifically for fanfiction writers, from character tracking to AI-assisted scene generation.
      </p>
      <a href={workbenchLink} class="btn-primary px-8 py-4 rounded-xl text-lg inline-block">
        Try It Free
      </a>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-24 relative z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Feature 1: AI Co-Writer -->
        <div class="glass-panel p-8 rounded-xl border border-[#3A3651] hover:border-[#8A2BE2] transition-all hover:shadow-[0_0_20px_rgba(138,43,226,0.15)] hover:-translate-y-1 group">
          <div class="w-14 h-14 rounded-xl bg-accent-gradient flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(138,43,226,0.4)]">
            <i data-lucide="wand-2" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#8A2BE2] group-hover:to-[#4A00E0] transition-colors">AI Co-Writer</h3>
          <p class="text-[#A09CB8] font-medium leading-relaxed">
            Generate scenes, dialogue, and descriptions with AI assistance. Control tone, pacing, and style with intuitive sliders.
          </p>
        </div>

        <!-- Feature 2: Lorebook Manager -->
        <div class="glass-panel p-8 rounded-xl border border-[#3A3651] hover:border-[#8A2BE2] transition-all hover:shadow-[0_0_20px_rgba(138,43,226,0.15)] hover:-translate-y-1 group">
          <div class="w-14 h-14 rounded-xl bg-accent-gradient flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(138,43,226,0.4)]">
            <i data-lucide="book-open" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#8A2BE2] group-hover:to-[#4A00E0] transition-colors">Lorebook Manager</h3>
          <p class="text-[#A09CB8] font-medium leading-relaxed">
            Track characters, locations, items, and plot points. The AI uses your lorebook to maintain perfect consistency.
          </p>
        </div>

        <!-- Feature 3: Distraction-Free Editor -->
        <div class="glass-panel p-8 rounded-xl border border-[#3A3651] hover:border-[#8A2BE2] transition-all hover:shadow-[0_0_20px_rgba(138,43,226,0.15)] hover:-translate-y-1 group">
          <div class="w-14 h-14 rounded-xl bg-accent-gradient flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(138,43,226,0.4)]">
            <i data-lucide="file-text" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#8A2BE2] group-hover:to-[#4A00E0] transition-colors">Distraction-Free Editor</h3>
          <p class="text-[#A09CB8] font-medium leading-relaxed">
            Clean, minimal writing interface designed for focus. Real-time word count, auto-save, and seamless chapter switching.
          </p>
        </div>

        <!-- Feature 4: Cloud Sync -->
        <div class="glass-panel p-8 rounded-xl border border-[#3A3651] hover:border-[#8A2BE2] transition-all hover:shadow-[0_0_20px_rgba(138,43,226,0.15)] hover:-translate-y-1 group">
          <div class="w-14 h-14 rounded-xl bg-accent-gradient flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(138,43,226,0.4)]">
            <i data-lucide="cloud" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#8A2BE2] group-hover:to-[#4A00E0] transition-colors">Cloud Sync</h3>
          <p class="text-[#A09CB8] font-medium leading-relaxed">
            Your stories are automatically saved to the cloud. Access your work from any device, anywhere, anytime.
          </p>
        </div>

        <!-- Feature 5: Guest Mode -->
        <div class="glass-panel p-8 rounded-xl border border-[#3A3651] hover:border-[#8A2BE2] transition-all hover:shadow-[0_0_20px_rgba(138,43,226,0.15)] hover:-translate-y-1 group">
          <div class="w-14 h-14 rounded-xl bg-accent-gradient flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(138,43,226,0.4)]">
            <i data-lucide="user" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#8A2BE2] group-hover:to-[#4A00E0] transition-colors">Guest Mode</h3>
          <p class="text-[#A09CB8] font-medium leading-relaxed">
            Start writing immediately without creating an account. Your work is saved locally, ready to sync when you sign up.
          </p>
        </div>

        <!-- Feature 6: Multi-Chapter Management -->
        <div class="glass-panel p-8 rounded-xl border border-[#3A3651] hover:border-[#8A2BE2] transition-all hover:shadow-[0_0_20px_rgba(138,43,226,0.15)] hover:-translate-y-1 group">
          <div class="w-14 h-14 rounded-xl bg-accent-gradient flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(138,43,226,0.4)]">
            <i data-lucide="library" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#8A2BE2] group-hover:to-[#4A00E0] transition-colors">Multi-Chapter Management</h3>
          <p class="text-[#A09CB8] font-medium leading-relaxed">
            Organize epic sagas with unlimited chapters. Drag to reorder, create chapter outlines, and track your progress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 relative z-10">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Transform Your Writing?</h2>
      <p class="text-lg text-[#A09CB8] mb-10 max-w-2xl mx-auto">
        Join thousands of fanfiction writers who are already creating amazing stories with AI assistance.
      </p>
      <a href={workbenchLink} class="btn-primary px-10 py-4 rounded-xl text-lg inline-block">
        Start Writing for Free
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-[#3A3651] bg-[#12101D]/80 relative z-10">
    <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Left: Logo -->
      <div class="flex items-center gap-2">
        <i data-lucide="feather" class="w-5 h-5 text-[#A09CB8]"></i>
        <span class="font-bold text-[#A09CB8]">AI Fanfiction</span>
      </div>

      <!-- Center: Links -->
      <div class="flex flex-wrap justify-center gap-6 text-sm font-medium text-[#A09CB8]">
        <a href="/pricing" class="hover:text-[#EAE6F8] transition-colors">Pricing</a>
        <a href="/community" class="hover:text-[#EAE6F8] transition-colors">Community</a>
        <a href="#" class="hover:text-[#EAE6F8] transition-colors">Terms of Service</a>
        <a href="#" class="hover:text-[#EAE6F8] transition-colors">Privacy Policy</a>
      </div>

      <!-- Right: Social -->
      <div class="flex items-center gap-4">
        <a href="#" class="text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" aria-label="Twitter">
          <i data-lucide="twitter" class="w-5 h-5"></i>
        </a>
        <a href="#" class="text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" aria-label="Discord">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
        </a>
        <a href="#" class="text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" aria-label="GitHub">
          <i data-lucide="github" class="w-5 h-5"></i>
        </a>
      </div>
    </div>
  </footer>
</BaseLayout>
