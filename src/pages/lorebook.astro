---
const description = "Lorebook - AI Fanfiction Generator";
const title = "Lorebook - AI Fanfiction";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Fonts: Manrope -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>

    <!-- Tailwind Configuration -->
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: {
                bg: '#12101D',
                text: '#EAE6F8',
              },
              secondary: {
                bg: 'rgba(28, 25, 41, 0.75)',
                text: '#A09CB8',
              },
              border: '#3A3651',
              danger: '#E05A5A',
              success: '#5AE08A'
            },
            fontFamily: {
              sans: ['Manrope', 'sans-serif'],
            }
          }
        }
      }
    </script>

    <style is:global>
      /* Global Styles */
      body {
        background-color: #12101D;
        color: #EAE6F8;
        font-family: 'Manrope', sans-serif;
        margin: 0;
        overflow: hidden;
      }

      /* Scrollbar Styling */
      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #3A3651;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #8A2BE2;
      }

      /* Gradient Text */
      .text-gradient {
        background: linear-gradient(135deg, #8A2BE2, #4A00E0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        color: transparent;
      }

      /* Primary Button */
      .btn-primary {
        background: linear-gradient(135deg, #8A2BE2, #4A00E0);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.15);
        transition: all 0.2s ease-out;
        color: #EAE6F8;
        font-weight: 700;
      }
      .btn-primary:hover {
        filter: brightness(1.1);
        box-shadow: 0 0 20px rgba(138, 43, 226, 0.5), inset 0 1px 0 rgba(255,255,255,0.15);
      }

      /* Input Field Glow */
      .input-field {
        background: rgba(18, 16, 29, 0.6);
        border: 1px solid #3A3651;
        color: #EAE6F8;
        transition: all 0.2s ease-out;
      }
      .input-field:focus {
        outline: none;
        border-color: #8A2BE2;
        box-shadow: 0 0 0 2px rgba(138, 43, 226, 0.25);
      }

      /* Ghost Input Focus */
      .input-ghost:focus {
        outline: none;
        box-shadow: none;
      }

      /* Left Entry Active Indicator */
      .entry-item {
        position: relative;
        transition: all 0.2s ease-out;
      }
      .entry-item.active {
        color: #EAE6F8;
        background: linear-gradient(90deg, rgba(138,43,226,0.1) 0%, transparent 100%);
      }
      .entry-item.active .entry-icon {
        color: #8A2BE2;
      }
      .entry-item.active::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0; width: 3px;
        background: linear-gradient(180deg, #8A2BE2, #4A00E0);
        box-shadow: 0 0 8px rgba(138,43,226,0.6);
        border-radius: 0 2px 2px 0;
      }

      /* Category Collapse Transition */
      .category-content {
        overflow: hidden;
        transition: max-height 0.3s ease-out;
      }
      .category-header[aria-expanded="false"] .category-icon {
        transform: rotate(-90deg);
      }

      /* Glassmorphism Panel */
      .glass-panel {
        background: rgba(28, 25, 41, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid #3A3651;
      }

      /* Dashed Upload Area */
      .upload-area {
        background: repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 10px,
          rgba(58, 54, 81, 0.2) 10px,
          rgba(58, 54, 81, 0.2) 20px
        );
        transition: all 0.2s ease;
      }
      .upload-area:hover {
        border-color: #8A2BE2;
        background-color: rgba(138, 43, 226, 0.05);
      }
    </style>

    <!-- Lucide Icons -->
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="flex h-screen w-full text-[#EAE6F8] bg-[#12101D]">

    <!-- LEFT COLUMN (ENTRY LIST) -->
    <aside class="w-[280px] flex-shrink-0 border-r border-[#3A3651] flex flex-col h-full bg-[#12101D] z-10 relative">

      <!-- Header -->
      <div class="px-5 pt-6 pb-4">
        <div class="flex items-center justify-between mb-4">
          <h1 class="font-extrabold text-xl tracking-wide flex items-center gap-2">
            <i data-lucide="book-marked" class="w-5 h-5 text-[#8A2BE2]"></i> Lorebook
          </h1>
          <button id="new-entry-btn" class="btn-primary w-8 h-8 rounded flex items-center justify-center hover:scale-105 transition-transform" title="New Entry">
            <i data-lucide="plus" class="w-4 h-4"></i>
          </button>
        </div>

        <!-- Search -->
        <div class="relative w-full">
          <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#A09CB8]"></i>
          <input type="text" placeholder="Search entries..." class="input-field w-full pl-9 pr-3 py-2 rounded-lg text-sm placeholder:text-[#3A3651]">
        </div>
      </div>

      <!-- Entry List (Scrollable) -->
      <div class="flex-1 overflow-y-auto px-3 pb-6 flex flex-col gap-2" id="entry-list-container">
        <!-- Categories and entries will be dynamically rendered here -->
      </div>
    </aside>

    <!-- RIGHT COLUMN (ENTRY EDITOR & EMPTY STATE) -->
    <main class="flex-1 flex flex-col relative bg-[#12101D] overflow-hidden h-full">

      <!-- EMPTY STATE -->
      <div id="empty-state" class="hidden absolute inset-0 flex flex-col items-center justify-center p-8 z-0">
        <div class="relative w-32 h-32 mb-8 flex items-center justify-center">
          <!-- Decorative elements -->
          <div class="absolute inset-0 bg-[#8A2BE2] opacity-10 rounded-full blur-2xl"></div>
          <i data-lucide="book-open" class="w-16 h-16 text-[#3A3651] absolute"></i>
          <i data-lucide="feather" class="w-10 h-10 text-[#8A2BE2] absolute -ml-6 -mt-6 animate-pulse"></i>
        </div>
        <h3 class="text-xl font-bold mb-2">Lorebook Archive</h3>
        <p class="text-[#A09CB8] mb-8 text-center max-w-sm">Select an entry from the left to view or edit its details, or create a new one to expand your world.</p>
        <button id="create-new-entry-btn" class="btn-primary px-6 py-3 rounded-xl flex items-center justify-center gap-2">
          <i data-lucide="plus" class="w-5 h-5"></i>
          Create New Entry
        </button>
      </div>

      <!-- ENTRY EDITOR STATE -->
      <div id="editor-state" class="flex flex-col h-full z-10 bg-[#12101D]">

        <!-- Scrollable Editor Content -->
        <div class="flex-1 overflow-y-auto px-8 md:px-16 py-10 pb-32">
          <div class="max-w-4xl mx-auto">

            <!-- Top Badge -->
            <div id="entry-type-badge" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[rgba(138,43,226,0.1)] border border-[rgba(138,43,226,0.3)] text-[#d4b3ff] text-xs font-bold tracking-wide uppercase mb-6">
              <i data-lucide="user" class="w-3.5 h-3.5"></i>
              Character
            </div>

            <!-- Entry Name Input -->
            <input id="entry-name-input" type="text" value="" class="input-ghost w-full bg-transparent text-4xl md:text-5xl font-extrabold text-[#EAE6F8] mb-8 placeholder:text-[#3A3651] border-b border-transparent focus:border-[#8A2BE2] pb-2 transition-colors" placeholder="Entry Name">

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

              <!-- Left Sub-column (Image & Attributes) -->
              <div class="lg:col-span-1 flex flex-col gap-8">

                <!-- Image Upload Area -->
                <div class="upload-area w-full aspect-[3/4] rounded-xl border-2 border-dashed border-[#3A3651] flex flex-col items-center justify-center p-6 text-center cursor-pointer group">
                  <div class="w-12 h-12 rounded-full bg-[rgba(255,255,255,0.05)] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                    <i data-lucide="image-plus" class="w-6 h-6 text-[#A09CB8] group-hover:text-[#8A2BE2] transition-colors"></i>
                  </div>
                  <span class="text-sm font-bold text-[#A09CB8] group-hover:text-[#EAE6F8] transition-colors">Upload Cover Image</span>
                  <span class="text-xs text-[#3A3651] mt-2">or Generate with AI</span>
                </div>

                <!-- Key Attributes -->
                <div>
                  <h3 class="text-sm font-bold text-[#EAE6F8] mb-4 uppercase tracking-wider flex items-center justify-between">
                    Key Attributes
                    <button class="text-xs text-[#8A2BE2] hover:text-[#d4b3ff] font-medium transition-colors flex items-center gap-1">
                      <i data-lucide="plus" class="w-3 h-3"></i> Add
                    </button>
                  </h3>

                  <div class="flex flex-col gap-3" id="attributes-list">
                    <!-- Row 1 -->
                    <div class="flex items-center gap-2 group">
                      <input type="text" value="Alias" class="input-field w-1/3 rounded p-2 text-xs font-medium text-[#A09CB8]" placeholder="Key">
                      <input type="text" value="The Shadow Weaver" class="input-field flex-1 rounded p-2 text-sm text-[#EAE6F8]" placeholder="Value">
                      <button class="w-6 h-6 flex items-center justify-center text-[#3A3651] hover:text-[#E05A5A] opacity-0 group-hover:opacity-100 transition-all"><i data-lucide="x" class="w-3.5 h-3.5"></i></button>
                    </div>
                    <!-- Row 2 -->
                    <div class="flex items-center gap-2 group">
                      <input type="text" value="Race" class="input-field w-1/3 rounded p-2 text-xs font-medium text-[#A09CB8]" placeholder="Key">
                      <input type="text" value="Human (Mage)" class="input-field flex-1 rounded p-2 text-sm text-[#EAE6F8]" placeholder="Value">
                      <button class="w-6 h-6 flex items-center justify-center text-[#3A3651] hover:text-[#E05A5A] opacity-0 group-hover:opacity-100 transition-all"><i data-lucide="x" class="w-3.5 h-3.5"></i></button>
                    </div>
                    <!-- Row 3 -->
                    <div class="flex items-center gap-2 group">
                      <input type="text" value="Affiliation" class="input-field w-1/3 rounded p-2 text-xs font-medium text-[#A09CB8]" placeholder="Key">
                      <input type="text" value="The Crimson Order" class="input-field flex-1 rounded p-2 text-sm text-[#EAE6F8]" placeholder="Value">
                      <button class="w-6 h-6 flex items-center justify-center text-[#3A3651] hover:text-[#E05A5A] opacity-0 group-hover:opacity-100 transition-all"><i data-lucide="x" class="w-3.5 h-3.5"></i></button>
                    </div>
                  </div>
                </div>

              </div>

              <!-- Right Sub-column (Description Rich Text) -->
              <div class="lg:col-span-2 flex flex-col h-full min-h-[500px]">
                <h3 class="text-sm font-bold text-[#EAE6F8] mb-4 uppercase tracking-wider">Description & Backstory</h3>

                <!-- Rich Text Editor Container -->
                <div class="glass-panel rounded-xl flex-1 flex flex-col overflow-hidden">
                  <!-- Toolbar -->
                  <div class="h-12 border-b border-[#3A3651] bg-[rgba(18,16,29,0.5)] flex items-center px-2 gap-1 flex-wrap">
                    <button class="p-1.5 rounded hover:bg-[rgba(255,255,255,0.05)] text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" title="Bold"><i data-lucide="bold" class="w-4 h-4"></i></button>
                    <button class="p-1.5 rounded hover:bg-[rgba(255,255,255,0.05)] text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" title="Italic"><i data-lucide="italic" class="w-4 h-4"></i></button>
                    <button class="p-1.5 rounded hover:bg-[rgba(255,255,255,0.05)] text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" title="Underline"><i data-lucide="underline" class="w-4 h-4"></i></button>
                    <div class="w-px h-4 bg-[#3A3651] mx-1"></div>
                    <button class="p-1.5 rounded hover:bg-[rgba(255,255,255,0.05)] text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" title="Heading"><i data-lucide="heading" class="w-4 h-4"></i></button>
                    <button class="p-1.5 rounded hover:bg-[rgba(255,255,255,0.05)] text-[#A09CB8] hover:text-[#EAE6F8] transition-colors" title="List"><i data-lucide="list" class="w-4 h-4"></i></button>
                    <div class="w-px h-4 bg-[#3A3651] mx-1"></div>
                    <button class="p-1.5 rounded hover:bg-[rgba(255,255,255,0.05)] text-[#A09CB8] hover:text-[#8A2BE2] transition-colors ml-auto flex items-center gap-1.5 px-2 font-medium text-xs">
                      <i data-lucide="sparkles" class="w-3.5 h-3.5"></i> Ask AI
                    </button>
                  </div>
                  <!-- Content Area -->
                  <div id="entry-description" contenteditable="true" class="flex-1 p-5 outline-none text-[#EAE6F8] leading-relaxed font-sans" style="font-size: 15px;">
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Fixed Bottom Action Bar -->
        <div class="absolute bottom-0 left-0 w-full bg-[rgba(18,16,29,0.95)] backdrop-blur-md border-t border-[#3A3651] px-8 py-4 flex justify-between items-center z-20">
          <button id="delete-entry-btn" class="text-sm font-bold text-[#E05A5A] hover:text-red-400 transition-colors flex items-center gap-2">
            <i data-lucide="trash-2" class="w-4 h-4"></i>
            Delete Entry
          </button>
          <div class="flex items-center gap-4">
            <span id="save-status" class="text-xs text-[#A09CB8] flex items-center gap-1 opacity-0 transition-opacity">
              <i data-lucide="check" class="w-3.5 h-3.5 text-[#5AE08A]"></i> Saved
            </span>
            <button id="save-entry-btn" class="btn-primary px-8 py-2.5 rounded-lg text-sm flex items-center gap-2">
              <i data-lucide="save" class="w-4 h-4"></i>
              Save Changes
            </button>
          </div>
        </div>

      </div>
    </main>

    <!-- Interactive Scripts -->
    <script is:inline>
      // Initialize icons
      lucide.createIcons();

      // State
      let currentStoryId = null;
      let currentEntryId = null;
      let loreEntries = [];
      let isNewEntry = false;

      // DOM Elements
      const emptyState = document.getElementById('empty-state');
      const editorState = document.getElementById('editor-state');
      const entryListContainer = document.getElementById('entry-list-container');
      const entryNameInput = document.getElementById('entry-name-input');
      const entryDescription = document.getElementById('entry-description');
      const entryTypeBadge = document.getElementById('entry-type-badge');
      const saveStatus = document.getElementById('save-status');

      // Type configurations for icons and colors
      const typeConfig = {
        'Character': { icon: 'user', color: 'from-purple-500 to-indigo-500', shape: 'rounded-full' },
        'Location': { icon: 'map-pin', color: 'bg-[#1C1929] text-emerald-400', shape: 'rounded' },
        'Item': { icon: 'sword', color: 'bg-[#1C1929] text-amber-400', shape: 'rounded' },
      };

      // Default types if custom type is not recognized
      function getTypeConfig(type) {
        return typeConfig[type] || { icon: 'book', color: 'bg-[#1C1929] text-[#A09CB8]', shape: 'rounded' };
      }

      // Parse storyId from URL
      function getStoryIdFromUrl() {
        const pathParts = window.location.pathname.split('/');
        // URL format: /lorebook?storyId=xxx or /workbench/xxx/lorebook
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('storyId') || pathParts[2]; // Try query param or path segment
      }

      // Fetch lore entries from API
      async function fetchLoreEntries() {
        if (!currentStoryId) return;

        try {
          const response = await fetch(`/api/lore?storyId=${currentStoryId}`);
          if (response.ok) {
            loreEntries = await response.json();
            renderEntryList();
          } else {
            console.error('Failed to fetch lore entries:', response.statusText);
          }
        } catch (error) {
          console.error('Error fetching lore entries:', error);
        }
      }

      // Render the entry list grouped by type
      function renderEntryList() {
        if (!entryListContainer) return;

        // Group entries by type
        const grouped = {};
        loreEntries.forEach(entry => {
          if (!grouped[entry.type]) {
            grouped[entry.type] = [];
          }
          grouped[entry.type].push(entry);
        });

        // Get all unique types, default types first
        const defaultTypes = ['Character', 'Location', 'Item'];
        const types = [...new Set([...defaultTypes, ...Object.keys(grouped)])].filter(t => grouped[t]);

        // Generate HTML
        let html = '';
        types.forEach((type, index) => {
          const entries = grouped[type];
          const categoryId = `cat-${type.toLowerCase().replace(/\s+/g, '-')}`;

          html += `
            <div>
              <button class="category-header w-full flex items-center justify-between px-2 py-2 text-[#A09CB8] hover:text-[#EAE6F8] transition-colors ${index > 0 ? 'mt-2' : ''}" aria-expanded="true" onclick="toggleCategory('${categoryId}', this)">
                <span class="text-xs font-bold uppercase tracking-wider">${type}s</span>
                <i data-lucide="chevron-down" class="category-icon w-4 h-4 transition-transform duration-200"></i>
              </button>
              <div id="${categoryId}" class="category-content flex flex-col" style="max-height: 500px;">
          `;

          entries.forEach(entry => {
            const config = getTypeConfig(type);
            const isActive = entry.id === currentEntryId ? 'active' : '';
            const nameClass = entry.id === currentEntryId ? 'text-[#EAE6F8]' : 'text-[#A09CB8] group-hover:text-[#EAE6F8]';

            html += `
              <div class="entry-item ${isActive} group flex items-center justify-between px-3 py-2 rounded-r-md cursor-pointer hover:bg-[rgba(255,255,255,0.03)]" onclick="loadEntry('${entry.id}')">
                <div class="flex items-center gap-3 overflow-hidden">
                  <div class="w-6 h-6 ${config.shape} ${type === 'Character' ? 'bg-gradient-to-tr ' + config.color : config.color} flex items-center justify-center flex-shrink-0 border border-[#3A3651]">
                    <i data-lucide="${config.icon}" class="w-3.5 h-3.5"></i>
                  </div>
                  <span class="text-sm font-medium ${nameClass} truncate transition-colors">${entry.name}</span>
                </div>
                <i data-lucide="edit-2" class="w-3.5 h-3.5 text-[#A09CB8] opacity-0 group-hover:opacity-100 transition-opacity hover:text-[#EAE6F8] flex-shrink-0"></i>
              </div>
            `;
          });

          html += `
              </div>
            </div>
          `;
        });

        entryListContainer.innerHTML = html;
        lucide.createIcons();
      }

      // Load an entry into the editor
      function loadEntry(entryId) {
        const entry = loreEntries.find(e => e.id === entryId);
        if (!entry) return;

        currentEntryId = entryId;
        isNewEntry = false;

        // Update UI
        entryNameInput.value = entry.name;
        entryDescription.innerHTML = entry.description || '<p></p>';
        updateTypeBadge(entry.type);

        // Update active state in sidebar
        renderEntryList();

        // Show editor
        showEditor();
      }

      // Update the type badge
      function updateTypeBadge(type) {
        const config = getTypeConfig(type);
        entryTypeBadge.innerHTML = `<i data-lucide="${config.icon}" class="w-3.5 h-3.5"></i> ${type}`;
        lucide.createIcons();
      }

      // Switch to empty state
      function showEmpty() {
        currentEntryId = null;
        isNewEntry = false;
        entryNameInput.value = '';
        entryDescription.innerHTML = '<p></p>';

        // Remove active state from all entry items
        const entryItems = document.querySelectorAll('.entry-item');
        entryItems.forEach(item => item.classList.remove('active'));

        editorState.classList.add('hidden');
        emptyState.classList.remove('hidden');
      }

      // Switch to editor state
      function showEditor() {
        emptyState.classList.add('hidden');
        editorState.classList.remove('hidden');
      }

      // Create new entry
      function createNewEntry() {
        currentEntryId = null;
        isNewEntry = true;

        // Clear form
        entryNameInput.value = '';
        entryDescription.innerHTML = '<p></p>';
        updateTypeBadge('Character');

        // Remove active state from sidebar
        const entryItems = document.querySelectorAll('.entry-item');
        entryItems.forEach(item => item.classList.remove('active'));

        // Show editor
        showEditor();
      }

      // Save entry (create or update)
      async function saveEntry() {
        const name = entryNameInput.value.trim();
        const description = entryDescription.innerHTML;
        const type = entryTypeBadge.textContent.trim();

        if (!name) {
          alert('Please enter an entry name');
          return;
        }

        showSaveStatus('Saving...');

        try {
          let savedEntry;

          if (isNewEntry || !currentEntryId) {
            // Create new entry
            const response = await fetch('/api/lore', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                storyId: currentStoryId,
                name,
                type,
                description,
              }),
            });

            if (response.ok) {
              savedEntry = await response.json();
              currentEntryId = savedEntry.id;
              isNewEntry = false;
            } else {
              throw new Error('Failed to create entry');
            }
          } else {
            // Update existing entry
            const response = await fetch(`/api/lore/${currentEntryId}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name, type, description }),
            });

            if (response.ok) {
              savedEntry = { id: currentEntryId, name, type, description };
            } else {
              throw new Error('Failed to update entry');
            }
          }

          // Update local state
          const index = loreEntries.findIndex(e => e.id === savedEntry.id);
          if (index >= 0) {
            loreEntries[index] = { ...loreEntries[index], ...savedEntry };
          } else {
            loreEntries.push(savedEntry);
          }

          // Refresh sidebar
          renderEntryList();
          showSaveStatus('Saved');

          setTimeout(() => {
            saveStatus.classList.add('opacity-0');
          }, 2000);

        } catch (error) {
          console.error('Error saving entry:', error);
          showSaveStatus('Error saving');
        }
      }

      // Delete entry
      async function deleteEntry() {
        if (!currentEntryId || isNewEntry) {
          showEmpty();
          return;
        }

        if (!confirm('Are you sure you want to delete this entry?')) {
          return;
        }

        try {
          const response = await fetch(`/api/lore/${currentEntryId}`, {
            method: 'DELETE',
          });

          if (response.ok) {
            // Remove from local state
            loreEntries = loreEntries.filter(e => e.id !== currentEntryId);
            currentEntryId = null;

            // Refresh sidebar and show empty state
            renderEntryList();
            showEmpty();
          } else {
            throw new Error('Failed to delete entry');
          }
        } catch (error) {
          console.error('Error deleting entry:', error);
          alert('Failed to delete entry');
        }
      }

      // Show save status
      function showSaveStatus(message) {
        if (message === 'Saving...') {
          saveStatus.innerHTML = '<i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i> Saving...';
        } else if (message === 'Saved') {
          saveStatus.innerHTML = '<i data-lucide="check" class="w-3.5 h-3.5 text-[#5AE08A]"></i> Saved';
        } else {
          saveStatus.innerHTML = `<i data-lucide="alert-circle" class="w-3.5 h-3.5 text-[#E05A5A]"></i> ${message}`;
        }
        saveStatus.classList.remove('opacity-0');
        lucide.createIcons();
      }

      // Toggle category expand/collapse
      function toggleCategory(id, btnElement) {
        const content = document.getElementById(id);
        const isExpanded = btnElement.getAttribute('aria-expanded') === 'true';

        if (isExpanded) {
          content.style.maxHeight = '0px';
          btnElement.setAttribute('aria-expanded', 'false');
        } else {
          content.style.maxHeight = '500px';
          btnElement.setAttribute('aria-expanded', 'true');
        }
      }

      // Event listeners
      document.getElementById('new-entry-btn').addEventListener('click', createNewEntry);
      document.getElementById('create-new-entry-btn').addEventListener('click', createNewEntry);
      document.getElementById('save-entry-btn').addEventListener('click', saveEntry);
      document.getElementById('delete-entry-btn').addEventListener('click', deleteEntry);

      // Initialize
      window.addEventListener('DOMContentLoaded', async () => {
        currentStoryId = getStoryIdFromUrl();

        if (!currentStoryId) {
          console.error('No story ID found in URL');
          return;
        }

        await fetchLoreEntries();

        // Show empty state initially
        showEmpty();
      });
    </script>
  </body>
</html>
